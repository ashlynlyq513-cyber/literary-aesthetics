{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: server",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "if (-not (Test-Path 'node_modules')) { & npm.cmd install; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE } }; & npm.cmd run dev"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        {
          "pattern": {
            "regexp": "^(?!x)x$"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Server running on http://localhost:3000"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "install: dependencies",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
