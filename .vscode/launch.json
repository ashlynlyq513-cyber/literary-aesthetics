{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch app in Edge",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "dev: server"
    },
    {
      "name": "Start dev server only",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    }
  ]
}
